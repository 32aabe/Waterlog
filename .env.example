# None of these are required for a local demo — with no .env at all,
# `pnpm dev` runs against an in-memory data store and an auto-"signed in"
# Local Dev Admin account (see README -> "Zero-dependency local demo
# mode"). Fill these in only to connect a real Manus app id / MySQL
# database / Forge credentials instead, e.g. for production, or to test
# real OAuth locally. Never fabricated as part of scaffolding this
# project — these are provisioned by the Manus platform, or manually if
# self-hosting.

# --- Server ---
DATABASE_URL=
JWT_SECRET=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
# Server-side Google Maps calls (reverse geocoding — see
# server/_core/geocode.ts). Must be a separate key from
# VITE_GOOGLE_MAPS_API_KEY below: that one is HTTP-referrer-restricted
# for the browser, this one needs IP-address restriction (or none) since
# server requests carry no referrer. Geocoding fails soft to null when
# unset — see describeLocation()'s catch block.
GOOGLE_MAPS_API_KEY=
NODE_ENV=development
PORT=3000
# Set to "true" only for a public, zero-dependency demo deployment (e.g.
# Railway) — see README's "Deploying a public demo" section. Leave unset
# for real production; see ENV.demoMode in server/_core/env.ts.
WATERLOG_DEMO_MODE=

# --- Client (must be prefixed VITE_ to be exposed to the browser) ---
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
# Google Maps JavaScript API key, HTTP-referrer-restricted to this app's
# domain(s). Powers the Map screen (client/src/components/Map.tsx); the
# map falls back to MapFallback's illustrated landscape when unset.
VITE_GOOGLE_MAPS_API_KEY=
# Client-side mirror of WATERLOG_DEMO_MODE above — must be set to the
# same value (both "true", or both unset). Gates MapHome's use of real
# browser geolocation so a demo deployment stays fixed on the NYC study
# area instead of centering/marking a reviewer's real location.
VITE_WATERLOG_DEMO_MODE=

# Optional — analytics only loads (see client/src/lib/analytics.ts) when
# BOTH of these are set. Leave blank for local dev; no crash either way.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
