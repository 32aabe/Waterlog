# Waterlog needs its own Manus app id / database / Forge credentials —
# distinct from Ver.2 "Brooktrack"'s. These are provisioned by the Manus
# platform (or manually if self-hosting) and are NOT fabricated as part of
# scaffolding this project. Copy this file to .env and fill in real values
# before running `pnpm dev`.

# --- Server ---
DATABASE_URL=
JWT_SECRET=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
NODE_ENV=development
PORT=3000

# --- Client (must be prefixed VITE_ to be exposed to the browser) ---
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
